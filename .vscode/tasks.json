            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true,
                "console": "externalTerminal"
            },
            "detail": "Task generated by Debugger."
        }
